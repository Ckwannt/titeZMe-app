rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    match /connection_test/{docId} {
      allow read, write: if isSignedIn();
    }

    // Phase 3: Primitive Definition
    function isSignedIn() {
      return request.auth != null && request.auth.uid != null;
    }

    // Admin check — accepts both isAdmin:true flag and role:'admin'
    function isAdmin() {
      return request.auth != null
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && (
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('isAdmin', false) == true
          ||
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', '') == 'admin'
        );
    }

    function isSuperAdmin() {
      return isAdmin()
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('isSuperAdmin', false) == true;
    }

    function isValidId(id) {
      return id is string && id.size() > 0 && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // Validations (Phase 2 & 4)
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role', 'firstName', 'lastName', 'createdAt', 'isOnboarded'])
        && data.uid is string && data.uid.size() <= 128
        && data.email is string && data.email.size() <= 256
        && data.role in ['client', 'professional', 'admin']
        && data.firstName is string && data.firstName.size() <= 100
        && data.lastName is string && data.lastName.size() <= 100
        && data.createdAt is number
        && data.isOnboarded is bool
        && (data.get('ownsShop', false) is bool)
        && data.get('favoriteBarbers', []) is list;
    }

    function isValidProfessionalProfile(data) {
      return data.keys().hasAll(['userId', 'profession', 'professionTier', 'isBookable', 'bio', 'city', 'country', 'isLive', 'approvalStatus'])
        && data.userId is string && data.userId.size() <= 128
        && data.profession is string && data.profession.size() > 0 && data.profession.size() <= 50
        && data.professionTier in ['artist', 'specialist']
        && data.isBookable is bool
        && data.bio is string && data.bio.size() <= 2000
        && data.city is string && data.city.size() <= 100
        && data.country is string && data.country.size() <= 100
        && data.isLive is bool
        && data.approvalStatus in ['pending', 'approved', 'rejected']
        && data.get('languages', []) is list
        && data.get('vibe', []) is list
        && data.get('specialties', []) is list
        && data.get('clientele', []) is list
        && data.get('photos', []) is list
        && data.get('videos', []) is list
        && (data.get('businessId', null) == null || data.get('businessId', null) is string)
        && (data.get('canManage', false) is bool)
        && (data.get('ownsBusiness', false) is bool)
        && (data.get('rating', 0) is number || data.get('rating', 0) is float)
        && data.get('totalCuts', 0) is number
        && data.get('reviewCount', 0) is number
        && (data.get('professionalCode', '') is string);
    }

    function isValidSchedule(data) {
      return data.keys().hasAll(['userId', 'timezone', 'weeklyHours', 'blockedDates'])
        && data.userId is string && data.userId.size() <= 128
        && data.timezone is string && data.timezone.size() <= 50
        && data.weeklyHours is map
        && data.blockedDates is list;
    }

    function isValidService(data) {
      return data.keys().hasAll(['providerId', 'providerType', 'name', 'duration', 'price'])
        && data.providerId is string && data.providerId.size() <= 128
        && data.providerType in ['barber', 'shop']
        && data.name is string && data.name.size() > 0 && data.name.size() <= 100
        && data.duration is number && data.duration > 0
        && data.price is number && data.price >= 0;
    }

    function isValidBooking(data) {
      return data.keys().hasAll(['clientId', 'barberId', 'date', 'startTime', 'status', 'price'])
        && data.clientId is string && data.clientId.size() <= 128
        && data.barberId is string && data.barberId.size() <= 128
        && (data.get('serviceId', '') == '' || data.get('serviceId', '') is string)
        && (data.get('serviceIds', []) is list)
        && data.date is string && data.date.size() <= 20
        && data.startTime is string && data.startTime.size() <= 20
        && (data.get('endTime', '') == '' || data.get('endTime', '') is string)
        && (data.get('totalDuration', 0) is number)
        && data.status in ['pending', 'confirmed', 'completed', 'cancelled', 'cancelled_by_client', 'cancelled_by_barber']
        && data.price is number
        && (data.get('shopId', null) == null || data.get('shopId', '') is string)
        && (data.get('paymentMethod', '') == '' || data.get('paymentMethod', '') is string)
        && (data.get('bookingContext', '') == '' || data.get('bookingContext', '') is string);
    }

    function isValidReview(data) {
      return data.keys().hasAll(['bookingId', 'providerId', 'providerType', 'clientId', 'rating', 'createdAt'])
        && data.bookingId is string && data.bookingId.size() <= 128
        && data.providerId is string && data.providerId.size() <= 128
        && data.providerType in ['barber', 'shop']
        && data.clientId is string && data.clientId.size() <= 128
        && data.rating is number && data.rating >= 1 && data.rating <= 5
        && data.get('comment', '') is string && data.get('comment', '').size() <= 1000
        && data.createdAt is number;
    }

    function isValidNotification(data) {
      return data.keys().hasAll(['userId', 'message', 'read', 'createdAt'])
        && data.userId is string && data.userId.size() <= 128
        && data.message is string && data.message.size() <= 500
        && data.read is bool
        && data.get('linkTo', null) == null || data.get('linkTo', null) is string
        && data.createdAt is number;
    }

    function isValidChallengeSubmission(data) {
      return data.keys().hasAll(['userId', 'type', 'submitterName', 'submitterCity', 'photos', 'description', 'status', 'voteCount', 'submittedAt', 'termsAcceptedAt', 'resubmissionCount'])
        && data.userId is string && data.userId.size() <= 128
        && data.type in ['barber', 'shop']
        && data.submitterName is string && data.submitterName.size() > 0 && data.submitterName.size() <= 200
        && data.submitterCity is string && data.submitterCity.size() <= 100
        && data.get('submitterAvatarUrl', '') is string
        && data.get('barberCode', '') is string
        && data.get('shopId', '') is string
        && data.photos is list && data.photos.size() >= 1 && data.photos.size() <= 4
        && data.get('videoUrl', '') is string
        && data.description is string && data.description.size() <= 1000
        && data.status in ['awaiting_payment', 'pending', 'approved', 'rejected']
        && (data.get('declaredAmount', 0) is number)
        && (data.get('declaredReference', '') is string)
        && (data.get('rejectionReason', '') is string)
        && data.voteCount is number && data.voteCount >= 0
        && data.submittedAt is number
        && (data.get('paidAt', 0) is number)
        && (data.get('approvedAt', 0) is number)
        && (data.get('rejectedAt', 0) is number)
        && data.termsAcceptedAt is number && data.termsAcceptedAt > 0
        && data.resubmissionCount is number && data.resubmissionCount >= 0;
    }

    function isValidChallengeVote(data) {
      return data.keys().hasAll(['voterUid', 'type', 'submissionId', 'votedAt'])
        && data.voterUid is string && data.voterUid.size() <= 128
        && data.type in ['barber', 'shop']
        && data.submissionId is string && data.submissionId.size() > 0 && data.submissionId.size() <= 200
        && data.votedAt is number;
    }

    function isChallengeSubmissionsOpen() {
      return exists(/databases/$(database)/documents/siteConfig/challenge)
        && get(/databases/$(database)/documents/siteConfig/challenge).data.submissionsOpenAt <= request.time.toMillis()
        && get(/databases/$(database)/documents/siteConfig/challenge).data.submissionsCloseAt > request.time.toMillis();
    }

    function isChallengeVotingOpen() {
      return exists(/databases/$(database)/documents/siteConfig/challenge)
        && get(/databases/$(database)/documents/siteConfig/challenge).data.votingOpenAt <= request.time.toMillis()
        && get(/databases/$(database)/documents/siteConfig/challenge).data.votingCloseAt > request.time.toMillis();
    }

    // Users
    match /users/{userId} {
      allow get: if request.auth != null;
      allow list: if isAdmin() || (isSignedIn() && resource.data.uid == request.auth.uid);

      allow create: if isSignedIn()
        && (
          isAdmin()
          || (
            request.auth.uid == userId
            && isValidUser(incoming())
            && incoming().uid == request.auth.uid
            && incoming().role in ['client', 'professional']
          )
        );

      allow update: if isSignedIn()
        && (
          (
            request.auth.uid == userId
            && isValidUser(incoming())
            && incoming().uid == existing().uid
            && (
              incoming().role == existing().role
              || incoming().role == 'professional'
            )
          )
          ||
          (
            request.auth.uid == userId
            && incoming().diff(existing())
              .affectedKeys()
              .hasOnly(['unreadCount'])
            && incoming().unreadCount is number
            && incoming().unreadCount >= 0
          )
          ||
          (
            request.auth.uid == userId
            && incoming().diff(existing())
              .affectedKeys()
              .hasOnly(['lastSeenAt'])
            && incoming().lastSeenAt is number
          )
          ||
          (
            request.auth.uid == userId
            && incoming().diff(existing())
              .affectedKeys()
              .hasOnly(['challengeVotedForBarber'])
            && incoming().challengeVotedForBarber is string
          )
          ||
          (
            request.auth.uid == userId
            && incoming().diff(existing())
              .affectedKeys()
              .hasOnly(['challengeVotedForShop'])
            && incoming().challengeVotedForShop is string
          )
          ||
          (
            isAdmin()
            && request.auth.uid != userId
            && incoming().diff(existing()).affectedKeys()
                 .hasOnly(['challengeVotedForBarber', 'challengeVotedForShop'])
          )
        );

      allow delete: if (
        (isSignedIn() && request.auth.uid == userId)
        || isAdmin()
      );
    }

    // Professional Profiles
    match /professionalProfiles/{profileId} {
      allow read: if true;

      // NOTE: isOnboarded is intentionally NOT required here. The professional
      // profile is created DURING onboarding (onboarding/barber handleLaunch
      // Step 1), before the users doc's isOnboarded flag is flipped true
      // (Step 4). Requiring it would deadlock onboarding. Verified email is
      // still enforced (the user must verify before reaching onboarding).
      allow create: if isSignedIn()
        && (
          isAdmin()
          || (
            request.auth.uid == incoming().userId
            && isValidProfessionalProfile(incoming())
            && request.auth.token.email_verified == true
          )
        );

      allow update: if (
        isAdmin()
        || (
          isSignedIn()
          && (existing().get('professionalCode', '') == '' || incoming().get('professionalCode', '') == existing().get('professionalCode', ''))
          && (
            request.auth.uid == existing().userId
            && isValidProfessionalProfile(incoming())
            && incoming().userId == existing().userId
            && incoming().approvalStatus == existing().approvalStatus
            && incoming().isLive == existing().isLive
            && !incoming().diff(existing()).affectedKeys().hasAny(['rating', 'reviewCount', 'totalCuts'])
            && (
              existing().get('experienceLocked', false) == false
              || (
                incoming().get('experienceStartYear', null) == existing().get('experienceStartYear', null)
                && incoming().get('dateOfBirth', null) == existing().get('dateOfBirth', null)
              )
            )
          )
        )
        // Business owner clearing a professional's businessId when
        // removing them from the team. Limited to businessId only,
        // and only when new businessId is null and the existing
        // businessId is a business the requester owns.
        || (
          isSignedIn()
          && existing().businessId != null
          && existing().businessId is string
          && exists(/databases/$(database)/documents/businesses/$(existing().businessId))
          && request.auth.uid == get(/databases/$(database)/documents/businesses/$(existing().businessId)).data.ownerId
          && incoming().businessId == null
          && incoming().diff(existing()).affectedKeys().hasOnly(['businessId'])
        )
      );

      allow delete: if (
        (isSignedIn() && request.auth.uid == profileId)
        || isAdmin()
      );
    }

    // Schedules
    match /schedules/{userId} {
      allow read: if true;
      allow create: if isSignedIn()
        && (
          isAdmin()
          || (
            request.auth.uid == incoming().userId
            && isValidSchedule(incoming())
          )
        );
      allow update: if isSignedIn()
        && request.auth.uid == existing().userId
        && isValidSchedule(incoming())
        && incoming().userId == existing().userId;
      // Delete allowed by the owning user (for account deletion) or admin.
      // Schedule doc IDs are `{uid}_shard_0`, so we check the stored userId
      // field on the doc itself rather than parsing the document ID.
      allow delete: if (
        (isSignedIn() && resource.data.userId == request.auth.uid)
        || isAdmin()
      );
    }

    // Businesses
    // Note: team-member self-remove no longer needs a special path here —
    // in the new model a professional leaves a business by setting their
    // own professionalProfiles/{uid}.businessId = null, which is handled
    // by the primary update rule on the professionalProfiles matcher.
    match /businesses/{businessId} {
      allow read: if true;

      allow create: if isSignedIn()
        && (
          isAdmin()
          || (
            request.auth.uid == incoming().ownerId
            && request.auth.token.email_verified == true
            && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isOnboarded == true
          )
        );

      allow update: if (
        isAdmin()
        || (
          isSignedIn()
          && request.auth.uid == existing().ownerId
          && incoming().ownerId == existing().ownerId
        )
      );

      allow delete: if (
        isAdmin()
        || (isSignedIn() && request.auth.uid == existing().ownerId)
      );
    }

    // Services
    match /services/{serviceId} {
      allow read: if true;

      // NOTE: isOnboarded is intentionally NOT required here. Initial services
      // are created DURING onboarding (onboarding/barber handleLaunch Step 3),
      // before isOnboarded is flipped true (Step 4). Verified email is still
      // enforced.
      allow create: if isSignedIn()
        && (
          isAdmin()
          || (
            request.auth.uid == incoming().providerId
            && isValidService(incoming())
            && exists(/databases/$(database)/documents/professionalProfiles/$(request.auth.uid))
            && request.auth.token.email_verified == true
          )
        );

      allow update: if isSignedIn()
        && request.auth.uid == existing().providerId
        && isValidService(incoming())
        && incoming().providerId == existing().providerId;

      allow delete: if isAdmin()
        || (isSignedIn() && request.auth.uid == existing().providerId);
    }

    // Invites — shop → barber team invitations
    // Required so shop owners and invited barbers can read their own invites
    // and update status (accept/decline). Without this block the invites
    // collection falls through to the global deny-all, breaking the shop
    // dashboard's pending-invites listener with permission-denied.
    match /invites/{inviteId} {
      allow read: if isSignedIn()
        && (
          resource.data.shopId == request.auth.uid
          || resource.data.barberId == request.auth.uid
          || isAdmin()
        );

      allow create: if isSignedIn()
        && incoming().shopId is string
        && incoming().barberId is string
        && incoming().status == 'pending'
        && incoming().shopId == request.auth.uid
        && exists(/databases/$(database)/documents/businesses/$(request.auth.uid));

      allow update: if isSignedIn()
        && (
          resource.data.barberId == request.auth.uid
          || resource.data.shopId == request.auth.uid
          || isAdmin()
        )
        && incoming().shopId == existing().shopId
        && incoming().barberId == existing().barberId;

      allow delete: if isSignedIn()
        && (
          resource.data.shopId == request.auth.uid
          || isAdmin()
        );
    }

    // Bookings
    match /bookings/{bookingId} {
      allow get: if isSignedIn()
        && (resource.data.clientId == request.auth.uid
          || resource.data.barberId == request.auth.uid
          || resource.data.shopId == request.auth.uid
          || isAdmin());

      allow list: if isSignedIn()
        && (resource.data.clientId == request.auth.uid
          || resource.data.barberId == request.auth.uid
          || resource.data.shopId == request.auth.uid
          || isAdmin());

      // Create: client creates a pending cash booking.
      // Deliberately minimal — no serviceId existence check because the app
      // uses serviceIds (array), not serviceId (string). Adding that check
      // caused every booking creation to fail with permission-denied.
      allow create: if isSignedIn()
        && request.auth.token.email_verified == true
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isOnboarded == true
        && request.auth.uid == incoming().clientId
        && request.auth.uid != incoming().barberId
        && incoming().status == 'pending'
        && incoming().paymentMethod == 'cash'
        && incoming().price is number
        && incoming().price >= 0
        && incoming().date is string
        && incoming().startTime is string
        && incoming().barberId is string
        && get(/databases/$(database)/documents/professionalProfiles/$(incoming().barberId)).data.isLive == true
        && get(/databases/$(database)/documents/professionalProfiles/$(incoming().barberId)).data.approvalStatus == 'approved'
        && incoming().appointmentTimestamp is number
        && incoming().appointmentTimestamp > request.time.toMillis()
        && exists(/databases/$(database)/documents/schedules/$(incoming().barberId + '_shard_0'));

      // Update: client can cancel their own booking; barber can accept/complete/cancel.
      // Admin can update anything. completedAt is allowed in the barber path.
      // Account-deletion clauses skip isValidBooking() because they only
      // touch a couple of fields (status/cancellationReason or id/name) and
      // do not need to re-validate the whole document shape.
      allow update: if (
        (
          isSignedIn()
          && isValidBooking(incoming())
          && (
            (
              request.auth.uid == existing().clientId
              && (incoming().status in ['cancelled_by_client'])
              && incoming().diff(existing()).affectedKeys()
                 .hasOnly(['status', 'updatedAt'])
              && (
                existing().get('appointmentTimestamp', 0) == 0
                || existing().get('appointmentTimestamp', 0)
                   - request.time.toMillis() > 7200000
              )
            )
            ||
            (
              request.auth.uid == existing().barberId
              && (incoming().status in ['confirmed', 'completed', 'cancelled', 'cancelled_by_barber'])
              && incoming().diff(existing()).affectedKeys()
                 .hasOnly(['status', 'updatedAt', 'completedAt'])
            )
          )
        )
        // Account deletion — client cancels their future booking with a reason
        || (
          isSignedIn()
          && request.auth.uid == existing().clientId
          && incoming().status == 'cancelled_by_client'
          && incoming().diff(existing()).affectedKeys()
             .hasOnly(['status', 'updatedAt', 'cancellationReason'])
        )
        // Account deletion — client anonymizes their past booking
        || (
          isSignedIn()
          && request.auth.uid == existing().clientId
          && incoming().clientId == 'deleted_user'
          && incoming().clientName == 'Anonymous'
          && incoming().diff(existing()).affectedKeys()
             .hasOnly(['clientId', 'clientName'])
        )
        // Account deletion — barber cancels their future booking with a reason
        || (
          isSignedIn()
          && request.auth.uid == existing().barberId
          && incoming().status == 'cancelled_by_barber'
          && incoming().diff(existing()).affectedKeys()
             .hasOnly(['status', 'updatedAt', 'cancellationReason'])
        )
        // Account deletion — barber anonymizes their past booking
        || (
          isSignedIn()
          && request.auth.uid == existing().barberId
          && incoming().barberId == 'deleted_barber'
          && incoming().barberName == 'Former Barber'
          && incoming().diff(existing()).affectedKeys()
             .hasOnly(['barberId', 'barberName'])
        )
        // Business deletion — owner cancels future booking with a reason
        || (
          isSignedIn()
          && existing().shopId != null
          && existing().shopId is string
          && exists(/databases/$(database)/documents/businesses/$(existing().shopId))
          && request.auth.uid == get(/databases/$(database)/documents/businesses/$(existing().shopId)).data.ownerId
          && incoming().status == 'cancelled'
          && incoming().diff(existing()).affectedKeys()
             .hasOnly(['status', 'updatedAt', 'cancellationReason'])
        )
        // Business deletion — owner anonymizes past booking
        || (
          isSignedIn()
          && existing().shopId != null
          && existing().shopId is string
          && exists(/databases/$(database)/documents/businesses/$(existing().shopId))
          && request.auth.uid == get(/databases/$(database)/documents/businesses/$(existing().shopId)).data.ownerId
          && incoming().shopId == 'deleted_shop'
          && incoming().shopName == 'Deleted Shop'
          && incoming().diff(existing()).affectedKeys()
             .hasOnly(['shopId', 'shopName'])
        )
        || isAdmin()
      );

      allow delete: if isAdmin();
    }

    // Reviews
    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if isSignedIn()
        && (
          isAdmin()
          || (
            request.auth.uid == incoming().clientId
            && incoming().providerId != request.auth.uid
            && isValidReview(incoming())
            && exists(/databases/$(database)/documents/professionalProfiles/$(incoming().providerId))
            && exists(/databases/$(database)/documents/bookings/$(incoming().bookingId))
            && get(/databases/$(database)/documents/bookings/$(incoming().bookingId)).data.clientId == request.auth.uid
            && get(/databases/$(database)/documents/bookings/$(incoming().bookingId)).data.status == 'completed'
            && !exists(/databases/$(database)/documents/reviews/$(incoming().bookingId + '_' + request.auth.uid))
          )
        );
      allow update: if (
        isAdmin()
        || (
          isSignedIn()
          && request.auth.uid == existing().clientId
          && isValidReview(incoming())
          && incoming().clientId == existing().clientId
          && incoming().providerId == existing().providerId
        )
        // Account deletion — client anonymizes their own past review.
        // Skips isValidReview() because we only touch clientId/clientName.
        || (
          isSignedIn()
          && request.auth.uid == existing().clientId
          && incoming().clientId == 'deleted_user'
          && incoming().clientName == 'Anonymous'
          && incoming().diff(existing()).affectedKeys().hasOnly(['clientId', 'clientName'])
        )
      );
      allow delete: if (
        isAdmin()
        // Barber deleting reviews they received (during account deletion).
        || (isSignedIn() && resource.data.providerId == request.auth.uid)
        // Client deleting their own review (e.g. retract, account deletion).
        || (isSignedIn() && resource.data.clientId == request.auth.uid)
      );
    }

    // Admin audit logs
    match /adminLogs/{logId} {
      allow read, write: if isAdmin();
    }

    // Aggregations — written by Cloud Function (Admin SDK,
    // bypasses rules). Public read needed for login page
    // barber count display (aggregations/stats).
    match /aggregations/{docId} {
      allow read: if true;
      allow write: if false;
    }

    // Feature requests (shop photos notify)
    match /featureRequests/{reqId} {
      allow read: if isAdmin();
      allow create: if isSignedIn();
    }

    // Admin user registry — super-admin only for write
    match /adminUsers/{adminId} {
      allow read: if isAdmin();
      allow create: if isSuperAdmin();
      allow update: if isSuperAdmin();
      allow delete: if isSuperAdmin();
    }

    // Locks for double booking checks
    // The transaction in book/[barberId]/page.tsx enforces overlap protection.
    // Security rules just ensure the user is signed in; the business logic
    // (preventing double booking) lives in the Firestore transaction itself.
    match /bookingLocks/{lockId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
        && lockId.matches('^[a-zA-Z0-9_\\-]+$')
        && lockId.size() <= 128;
      allow update: if isSignedIn()
        && lockId.matches('^[a-zA-Z0-9_\\-]+$');
      allow delete: if isSignedIn();
    }

    // Notifications
    match /notifications/{notificationId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn()
        && isValidNotification(incoming())
        && (
          isAdmin()
          || incoming().userId == request.auth.uid
          || (
            incoming().type == 'booking_cancelled'
            && incoming().bookingId is string
            && exists(/databases/$(database)/documents/bookings/$(incoming().bookingId))
            && get(/databases/$(database)/documents/bookings/$(incoming().bookingId)).data.shopId == request.auth.uid
            && incoming().userId == get(/databases/$(database)/documents/bookings/$(incoming().bookingId)).data.clientId
          )
        );

      allow update: if isSignedIn()
        && request.auth.uid == existing().userId
        && isValidNotification(incoming())
        && incoming().userId == existing().userId
        && incoming().diff(existing()).affectedKeys().hasOnly(['read']);

      // Delete allowed by the recipient (for account deletion / dismiss) or admin.
      allow delete: if (
        (isSignedIn() && resource.data.userId == request.auth.uid)
        || isAdmin()
      );
    }

    // Site-wide config — public read, admin-only write
    match /siteConfig/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Contact form submissions — public create with shape validation,
    // admin-only read/update/delete.
    match /contactMessages/{msgId} {
      allow create: if
        request.resource.data.name is string &&
        request.resource.data.name.size() <= 100 &&
        request.resource.data.email is string &&
        request.resource.data.email.size() <= 200 &&
        request.resource.data.message is string &&
        request.resource.data.message.size() <= 2000 &&
        request.resource.data.role is string &&
        request.resource.data.read == false;

      allow read, update, delete: if isAdmin();
    }

    // Challenge submissions — leaderboard entries (one per user per type).
    // Public read for approved submissions; owner/admin read for any status.
    // Voting counter `voteCount` is reserved for Cloud Function writes only.
    match /challengeSubmissions/{submissionId} {
      allow get: if (
        isAdmin()
        || resource == null
        || (isSignedIn() && resource.data.userId == request.auth.uid)
        || resource.data.status == 'approved'
      );

      allow list: if (
        isAdmin()
        || resource == null
        || resource.data.status == 'approved'
        || (isSignedIn() && resource.data.userId == request.auth.uid)
      );

      allow create: if isSignedIn()
        && isValidId(submissionId)
        && isChallengeSubmissionsOpen()
        && isValidChallengeSubmission(incoming())
        && incoming().userId == request.auth.uid
        && submissionId == request.auth.uid + '_' + incoming().type
        && incoming().status == 'awaiting_payment'
        && incoming().voteCount == 0
        && incoming().resubmissionCount == 0;

      allow update: if (
        isAdmin()
        && incoming().voteCount == existing().voteCount
        && incoming().userId == existing().userId
        && incoming().type == existing().type
      ) || (
        // Path 1 — owner marks as paid
        isSignedIn()
        && request.auth.uid == existing().userId
        && existing().status == 'awaiting_payment'
        && incoming().status == 'pending'
        && incoming().diff(existing()).affectedKeys().hasOnly(['status', 'paidAt', 'declaredAmount', 'declaredReference'])
        && incoming().paidAt is number
      ) || (
        // Path 2 — owner resubmits after rejection
        isSignedIn()
        && request.auth.uid == existing().userId
        && existing().status == 'rejected'
        && incoming().status == 'awaiting_payment'
        && isChallengeSubmissionsOpen()
        && incoming().diff(existing()).affectedKeys().hasOnly(['photos', 'videoUrl', 'description', 'status', 'submittedAt', 'resubmissionCount'])
        && incoming().resubmissionCount == existing().resubmissionCount + 1
        && incoming().photos is list && incoming().photos.size() >= 1 && incoming().photos.size() <= 4
        && incoming().description.size() <= 1000
      );

      allow delete: if isAdmin();
    }

    // Challenge votes — one doc per (voter, type). Immutable once created.
    // Email-verified gate enforced here only; no other collection uses it.
    // Vote counter is denormalized to challengeSubmissions.voteCount via
    // Cloud Function (Step 4) — never read this collection for counting.
    match /challengeVotes/{voteId} {
      allow get: if isAdmin()
        || resource == null
        || (isSignedIn() && resource.data.voterUid == request.auth.uid);

      allow list: if isAdmin()
        || resource == null
        || (isSignedIn() && resource.data.voterUid == request.auth.uid);

      allow create: if isSignedIn()
        && request.auth.token.email_verified == true
        && isValidId(voteId)
        && isChallengeVotingOpen()
        && isValidChallengeVote(incoming())
        && incoming().voterUid == request.auth.uid
        && voteId == request.auth.uid + '_' + incoming().type
        && exists(/databases/$(database)/documents/challengeSubmissions/$(incoming().submissionId))
        && get(/databases/$(database)/documents/challengeSubmissions/$(incoming().submissionId)).data.status == 'approved'
        && get(/databases/$(database)/documents/challengeSubmissions/$(incoming().submissionId)).data.type == incoming().type;

      allow update: if false;

      allow delete: if isAdmin();
    }
  }
}

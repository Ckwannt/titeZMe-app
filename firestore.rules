rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Global deny-all — only explicitly granted rules permit access
    match /{document=**} {
      allow read, write: if false;
    }

    // ─── Helpers ────────────────────────────────────────────────────────────

    function isSignedIn() {
      return request.auth != null && request.auth.uid != null;
    }

    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // ─── Validation functions ────────────────────────────────────────────────

    // role is strictly 'client' or 'barber' — 'shop_owner' does not exist
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role', 'firstName', 'lastName', 'createdAt', 'isOnboarded'])
        && data.uid is string && data.uid.size() <= 128
        && data.email is string && data.email.size() <= 256
        && data.role in ['client', 'barber']
        && data.firstName is string && data.firstName.size() > 0 && data.firstName.size() <= 100
        && data.lastName is string && data.lastName.size() <= 100
        && data.createdAt is number
        && data.isOnboarded is bool
        && data.get('ownsShop', false) is bool
        && data.get('favoriteBarbers', []) is list;
    }

    // rating, reviewCount, totalCuts are Cloud Function-managed — never written directly by clients
    function isValidBarberProfile(data) {
      return data.keys().hasAll(['userId', 'bio', 'city', 'isLive'])
        && data.userId is string && data.userId.size() <= 128
        && data.bio is string && data.bio.size() <= 2000
        && data.city is string && data.city.size() <= 100
        && data.get('languages', []) is list
        && data.get('vibes', []) is list
        && data.get('specialties', []) is list
        && data.get('photos', []) is list
        && data.get('isSolo', true) is bool
        && (data.get('shopId', null) == null || data.get('shopId', null) is string)
        && data.get('ownsShop', false) is bool
        && (data.get('rating', 0) is number || data.get('rating', 0.0) is float)
        && data.get('totalCuts', 0) is number
        && data.get('reviewCount', 0) is number
        && data.isLive is bool
        && (data.get('barberCode', '') == ''
            || (data.get('barberCode', '') is string
                && data.get('barberCode', '').matches('^TZB-[A-Z0-9]{6}$')));
    }

    // status is 'active' or 'inactive' only — 'suspended' is not a valid client-visible status
    function isValidBarbershop(data) {
      return data.keys().hasAll(['ownerId', 'name', 'contactPhone', 'address', 'status', 'createdAt'])
        && data.ownerId is string && data.ownerId.size() <= 128
        && data.name is string && data.name.size() > 0 && data.name.size() <= 100
        && data.contactPhone is string && data.contactPhone.size() <= 50
        && data.address is map
        && data.address.keys().hasAll(['street', 'city', 'country', 'number', 'postalCode', 'floor'])
        && data.address.street is string && data.address.street.size() <= 200
        && data.address.city is string && data.address.city.size() <= 100
        && data.address.country is string && data.address.country.size() <= 100
        && data.address.number is string && data.address.number.size() <= 50
        && data.address.postalCode is string && data.address.postalCode.size() <= 50
        && data.address.floor is string && data.address.floor.size() <= 100
        && data.get('googleMapsUrl', '') is string
        && data.get('description', '') is string && data.get('description', '').size() <= 2000
        && data.get('photos', []) is list
        && data.get('barbers', []) is list
        && data.status in ['active', 'inactive']
        && data.createdAt is number;
    }

    // Supports both durationMinutes and legacy duration field names
    function isValidService(data) {
      return data.keys().hasAll(['providerId', 'providerType', 'name', 'price', 'isActive'])
        && data.providerId is string && data.providerId.size() <= 128
        && data.providerType in ['barber', 'shop']
        && data.name is string && data.name.size() > 0 && data.name.size() <= 100
        && data.price is number && data.price > 0
        && data.isActive is bool
        && (data.get('durationMinutes', data.get('duration', 0)) > 0);
    }

    // paymentMethod is always 'cash' (MVP); bookingContext is 'solo' or 'shop'
    function isValidBooking(data) {
      return data.keys().hasAll(['clientId', 'barberId', 'bookingContext', 'serviceIds',
                                  'totalPrice', 'totalDuration', 'startTime', 'endTime',
                                  'status', 'paymentMethod', 'createdAt'])
        && data.clientId is string && data.clientId.size() <= 128
        && data.barberId is string && data.barberId.size() <= 128
        && data.bookingContext in ['solo', 'shop']
        && data.serviceIds is list && data.serviceIds.size() > 0
        && data.totalPrice is number && data.totalPrice >= 0
        && data.totalDuration is number && data.totalDuration > 0
        && data.startTime is string && data.startTime.size() <= 50
        && data.endTime is string && data.endTime.size() <= 50
        && data.status in ['pending', 'confirmed', 'completed',
                           'cancelled', 'cancelled_by_client', 'cancelled_by_barber']
        && data.paymentMethod == 'cash'
        && data.createdAt is number
        && (data.get('shopId', null) == null || data.get('shopId', null) is string);
    }

    function isValidSchedule(data) {
      return data.keys().hasAll(['userId', 'timezone', 'weeklyHours', 'blockedDates'])
        && data.userId is string && data.userId.size() <= 128
        && data.timezone is string && data.timezone.size() <= 50
        && data.weeklyHours is map
        && data.blockedDates is list;
    }

    function isValidInvite(data) {
      return data.keys().hasAll(['shopId', 'shopName', 'barberId', 'status', 'createdAt'])
        && data.shopId is string && data.shopId.size() <= 128
        && data.shopName is string && data.shopName.size() <= 100
        && data.barberId is string && data.barberId.size() <= 128
        && data.status in ['pending', 'accepted', 'declined', 'cancelled']
        && data.createdAt is number
        && data.get('respondedAt', 0) is number;
    }

    // barberId replaces the generic providerId/providerType pattern for reviews
    function isValidReview(data) {
      return data.keys().hasAll(['bookingId', 'clientId', 'barberId', 'rating', 'createdAt'])
        && data.bookingId is string && data.bookingId.size() <= 128
        && data.clientId is string && data.clientId.size() <= 128
        && data.barberId is string && data.barberId.size() <= 128
        && data.rating is number && data.rating >= 1 && data.rating <= 5
        && data.get('comment', '') is string && data.get('comment', '').size() <= 1000
        && data.createdAt is number
        && (data.get('shopId', null) == null || data.get('shopId', null) is string);
    }

    function isValidNotification(data) {
      return data.keys().hasAll(['userId', 'message', 'read', 'createdAt'])
        && data.userId is string && data.userId.size() <= 128
        && data.message is string && data.message.size() <= 500
        && data.read is bool
        && (data.get('linkTo', null) == null || data.get('linkTo', null) is string)
        && data.createdAt is number;
    }

    // ─── users ───────────────────────────────────────────────────────────────
    // Any signed-in user can GET a user doc (needed for client names in bookings
    // and reviewer names in reviews). Field-level masking is not possible in
    // Firestore rules — the app must only expose public fields to non-owners.
    // LIST is restricted to own documents to prevent enumeration.
    // uid and role are immutable after creation.
    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn() && resource.data.uid == request.auth.uid;

      allow create: if isSignedIn()
        && request.auth.uid == userId
        && isValidUser(incoming())
        && incoming().uid == request.auth.uid;

      allow update: if isSignedIn()
        && request.auth.uid == userId
        && isValidUser(incoming())
        && incoming().uid == existing().uid
        && incoming().role == existing().role;

      allow delete: if isSignedIn() && request.auth.uid == userId;
    }

    // ─── barberProfiles (also referred to as "barbers") ──────────────────────
    // Fully public read — no auth required for browse/discovery.
    // rating, reviewCount, totalCuts are protected: clients cannot change them
    // because the rule requires incoming values to match the stored values.
    // Cloud Functions use the Admin SDK which bypasses these rules entirely.
    match /barberProfiles/{profileId} {
      allow read: if true;

      allow create: if isSignedIn()
        && request.auth.uid == profileId
        && request.auth.uid == incoming().userId
        && isValidBarberProfile(incoming());

      allow update: if isSignedIn()
        && request.auth.uid == profileId
        && existing().userId == request.auth.uid
        && isValidBarberProfile(incoming())
        && incoming().userId == existing().userId
        && incoming().get('rating', 0) == existing().get('rating', 0)
        && incoming().get('reviewCount', 0) == existing().get('reviewCount', 0)
        && incoming().get('totalCuts', 0) == existing().get('totalCuts', 0);

      allow delete: if isSignedIn() && request.auth.uid == profileId;
    }

    // ─── barbershops ─────────────────────────────────────────────────────────
    // Fully public read. shopId equals the owner's uid (doc ID = owner uid).
    // ownerId is immutable after creation.
    match /barbershops/{shopId} {
      allow read: if true;

      allow create: if isSignedIn()
        && request.auth.uid == shopId
        && request.auth.uid == incoming().ownerId
        && isValidBarbershop(incoming());

      allow update: if isSignedIn()
        && request.auth.uid == shopId
        && request.auth.uid == existing().ownerId
        && isValidBarbershop(incoming())
        && incoming().ownerId == existing().ownerId;

      allow delete: if isSignedIn() && request.auth.uid == existing().ownerId;
    }

    // ─── bookings ────────────────────────────────────────────────────────────
    // Client, barber, and shop owner (matched via shopId == auth uid) can read.
    // Only the status field may change after creation; all other fields are frozen.
    // Deletes are permanently disabled — use cancelled_by_* status instead.
    match /bookings/{bookingId} {
      allow get: if isSignedIn()
        && (resource.data.clientId == request.auth.uid
            || resource.data.barberId == request.auth.uid
            || (resource.data.get('shopId', '') != ''
                && resource.data.shopId == request.auth.uid));

      allow list: if isSignedIn()
        && (resource.data.clientId == request.auth.uid
            || resource.data.barberId == request.auth.uid
            || (resource.data.get('shopId', '') != ''
                && resource.data.shopId == request.auth.uid));

      allow create: if isSignedIn()
        && incoming().clientId == request.auth.uid
        && isValidBooking(incoming())
        && incoming().status == 'pending'
        && incoming().paymentMethod == 'cash';

      allow update: if isSignedIn()
        && isValidBooking(incoming())
        && incoming().clientId == existing().clientId
        && incoming().barberId == existing().barberId
        && incoming().createdAt == existing().createdAt
        && (
          (request.auth.uid == existing().clientId
            && incoming().status == 'cancelled_by_client'
            && incoming().diff(existing()).affectedKeys().hasOnly(['status', 'updatedAt']))
          ||
          (request.auth.uid == existing().barberId
            && incoming().status in ['confirmed', 'cancelled_by_barber']
            && incoming().diff(existing()).affectedKeys().hasOnly(['status', 'updatedAt']))
        );

      allow delete: if false;
    }

    // ─── services ────────────────────────────────────────────────────────────
    // Fully public read (shown on barber and shop public profiles).
    // providerId equals the barber's uid or the shop owner's uid (since shopId == ownerId).
    match /services/{serviceId} {
      allow read: if true;

      allow create: if isSignedIn()
        && incoming().providerId == request.auth.uid
        && isValidService(incoming());

      allow update: if isSignedIn()
        && existing().providerId == request.auth.uid
        && isValidService(incoming())
        && incoming().providerId == existing().providerId;

      allow delete: if isSignedIn() && existing().providerId == request.auth.uid;
    }

    // ─── schedules ───────────────────────────────────────────────────────────
    // Fully public read (needed to render availability on public profiles).
    // Owner is identified by the userId field matching auth uid.
    match /schedules/{scheduleId} {
      allow read: if true;

      allow create: if isSignedIn()
        && request.auth.uid == incoming().userId
        && isValidSchedule(incoming());

      allow update: if isSignedIn()
        && request.auth.uid == existing().userId
        && isValidSchedule(incoming())
        && incoming().userId == existing().userId;

      allow delete: if isSignedIn() && request.auth.uid == existing().userId;
    }

    // ─── invites ─────────────────────────────────────────────────────────────
    // Barber sees invites addressed to them; shop owner sees invites they sent.
    // Only shop owners can create (status must be 'pending' on creation).
    // Barber can respond with 'accepted' or 'declined' (must set respondedAt).
    // Shop owner can cancel. Only shop owner can delete, and only while 'pending'.
    match /invites/{inviteId} {
      allow get: if isSignedIn()
        && (resource.data.barberId == request.auth.uid
            || resource.data.shopId == request.auth.uid);

      allow list: if isSignedIn()
        && (resource.data.barberId == request.auth.uid
            || resource.data.shopId == request.auth.uid);

      allow create: if isSignedIn()
        && incoming().shopId == request.auth.uid
        && isValidInvite(incoming())
        && incoming().status == 'pending';

      allow update: if isSignedIn()
        && isValidInvite(incoming())
        && incoming().shopId == existing().shopId
        && incoming().barberId == existing().barberId
        && incoming().createdAt == existing().createdAt
        && (
          (request.auth.uid == existing().barberId
            && incoming().status in ['accepted', 'declined']
            && incoming().diff(existing()).affectedKeys().hasOnly(['status', 'respondedAt'])
            && incoming().keys().hasAll(['respondedAt']))
          ||
          (request.auth.uid == existing().shopId
            && incoming().status == 'cancelled'
            && incoming().diff(existing()).affectedKeys().hasOnly(['status', 'respondedAt']))
        );

      allow delete: if isSignedIn()
        && request.auth.uid == existing().shopId
        && existing().status == 'pending';
    }

    // ─── reviews ─────────────────────────────────────────────────────────────
    // Fully public read (shown on barber profiles). Write-once after creation.
    // One-review-per-booking cannot be enforced at the rules layer without knowing
    // the target document ID in advance — enforced at the application layer instead.
    match /reviews/{reviewId} {
      allow read: if true;

      allow create: if isSignedIn()
        && incoming().clientId == request.auth.uid
        && isValidReview(incoming());

      allow update: if false;
      allow delete: if false;
    }

    // ─── notifications ───────────────────────────────────────────────────────
    // Strictly private — only the owner can read, update, or delete.
    // Only the 'read' field may be changed on update (mark-as-read).
    match /notifications/{notificationId} {
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;

      allow create: if isSignedIn()
        && isValidNotification(incoming());

      allow update: if isSignedIn()
        && existing().userId == request.auth.uid
        && incoming().userId == existing().userId
        && isValidNotification(incoming())
        && incoming().diff(existing()).affectedKeys().hasOnly(['read']);

      allow delete: if isSignedIn() && existing().userId == request.auth.uid;
    }

    // ─── aggregations ────────────────────────────────────────────────────────
    // Doc IDs follow the pattern {barberId}_{YYYY_MM}.
    // Barbers can read their own docs; shop owners can read all their barbers' docs
    // (identified by having a barbershops/{uid} document).
    // All writes are Cloud Function-only via Admin SDK — deny all direct client writes.
    match /aggregations/{docId} {
      allow get: if isSignedIn()
        && (docId.matches('^' + request.auth.uid + '_.*')
            || exists(/databases/$(database)/documents/barbershops/$(request.auth.uid)));

      allow list: if isSignedIn()
        && (docId.matches('^' + request.auth.uid + '_.*')
            || exists(/databases/$(database)/documents/barbershops/$(request.auth.uid)));

      allow write: if false;
    }

    // ─── bookingLocks (concurrency guard) ────────────────────────────────────
    match /bookingLocks/{lockId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }
  }
}
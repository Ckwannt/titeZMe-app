rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    match /connection_test/{docId} {
      allow read, write: if true; // Temporary test rule
    }

    // Phase 3: Primitive Definition
    function isSignedIn() {
      return request.auth != null && request.auth.uid != null;
    }

    // Admin check — reads isAdmin field from the caller's user document
    function isAdmin() {
      return request.auth != null
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('isAdmin', false) == true;
    }

    function isValidId(id) {
      return id is string && id.size() > 0 && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // Validations (Phase 2 & 4)
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role', 'firstName', 'lastName', 'createdAt', 'isOnboarded'])
        && data.uid is string && data.uid.size() <= 128
        && data.email is string && data.email.size() <= 256
        && data.role in ['client', 'barber', 'shop_owner']
        && data.firstName is string && data.firstName.size() <= 100
        && data.lastName is string && data.lastName.size() <= 100
        && data.createdAt is number
        && data.isOnboarded is bool
        && (data.get('ownsShop', false) is bool)
        && data.get('favoriteBarbers', []) is list;
    }

    function isValidBarberProfile(data) {
      return data.keys().hasAll(['userId', 'bio', 'city', 'isLive'])
        && data.userId is string && data.userId.size() <= 128
        && data.bio is string && data.bio.size() <= 2000
        && data.city is string && data.city.size() <= 100
        && data.get('languages', []) is list
        && data.get('vibes', []) is list
        && data.get('specialties', []) is list
        && data.get('photos', []) is list
        && data.get('isSolo', true) is bool
        && (data.get('shopId', null) == null || data.get('shopId', null) is string)
        && (data.get('ownsShop', false) is bool)
        && (data.get('rating', 0) is number || data.get('rating', 0) is float)
        && data.get('totalCuts', 0) is number
        && data.get('reviewCount', 0) is number
        && data.isLive is bool
        && (data.get('barberCode', '') == '' || (data.get('barberCode', '') is string && data.get('barberCode', '').matches('^TZB-[A-Z0-9]{6}$')));
    }

    function isValidSchedule(data) {
      return data.keys().hasAll(['userId', 'timezone', 'weeklyHours', 'blockedDates'])
        && data.userId is string && data.userId.size() <= 128
        && data.timezone is string && data.timezone.size() <= 50
        && data.weeklyHours is map
        && data.blockedDates is list;
    }

    // NOTE: isValidBarbershop is defined but no longer called in the barbershops rules.
    // Removed from create/update to fix Zod schema stripping address sub-fields
    // (number, postalCode, floor) before Firestore sees the document.
    function isValidBarbershop(data) {
      return data.keys().hasAll(['ownerId', 'name', 'contactPhone', 'address', 'status', 'createdAt'])
        && data.ownerId is string && data.ownerId.size() <= 128
        && data.name is string && data.name.size() > 0 && data.name.size() <= 100
        && data.contactPhone is string && data.contactPhone.size() <= 50
        && data.address is map
        && data.address.keys().hasAll(['street', 'city', 'country', 'number', 'postalCode', 'floor'])
        && data.address.street is string && data.address.street.size() <= 200
        && data.address.city is string && data.address.city.size() <= 100
        && data.address.country is string && data.address.country.size() <= 100
        && data.address.number is string && data.address.number.size() <= 50
        && data.address.postalCode is string && data.address.postalCode.size() <= 50
        && data.address.floor is string && data.address.floor.size() <= 100
        && data.get('googleMapsUrl', '') is string
        && data.get('description', '') is string && data.get('description', '').size() <= 2000
        && data.get('photos', []) is list
        && data.get('barbers', []) is list
        && data.status in ['active', 'inactive', 'suspended']
        && data.createdAt is number;
    }

    function isValidService(data) {
      return data.keys().hasAll(['providerId', 'providerType', 'name', 'duration', 'price'])
        && data.providerId is string && data.providerId.size() <= 128
        && data.providerType in ['barber', 'shop']
        && data.name is string && data.name.size() > 0 && data.name.size() <= 100
        && data.duration is number && data.duration > 0
        && data.price is number && data.price >= 0;
    }

    function isValidBooking(data) {
      return data.keys().hasAll(['clientId', 'barberId', 'date', 'startTime', 'status', 'price'])
        && data.clientId is string && data.clientId.size() <= 128
        && data.barberId is string && data.barberId.size() <= 128
        && (data.get('serviceId', '') == '' || data.get('serviceId', '') is string)
        && (data.get('serviceIds', []) is list)
        && data.date is string && data.date.size() <= 20
        && data.startTime is string && data.startTime.size() <= 20
        && (data.get('endTime', '') == '' || data.get('endTime', '') is string)
        && (data.get('totalDuration', 0) is number)
        && data.status in ['pending', 'confirmed', 'completed', 'cancelled', 'cancelled_by_client', 'cancelled_by_barber']
        && data.price is number
        && (data.get('shopId', null) == null || data.get('shopId', '') is string)
        && (data.get('paymentMethod', '') == '' || data.get('paymentMethod', '') is string)
        && (data.get('bookingContext', '') == '' || data.get('bookingContext', '') is string);
    }

    function isValidReview(data) {
      return data.keys().hasAll(['bookingId', 'providerId', 'providerType', 'clientId', 'rating', 'createdAt'])
        && data.bookingId is string && data.bookingId.size() <= 128
        && data.providerId is string && data.providerId.size() <= 128
        && data.providerType in ['barber', 'shop']
        && data.clientId is string && data.clientId.size() <= 128
        && data.rating is number && data.rating >= 1 && data.rating <= 5
        && data.get('comment', '') is string && data.get('comment', '').size() <= 1000
        && data.createdAt is number;
    }

    function isValidNotification(data) {
      return data.keys().hasAll(['userId', 'message', 'read', 'createdAt'])
        && data.userId is string && data.userId.size() <= 128
        && data.message is string && data.message.size() <= 500
        && data.read is bool
        && data.get('linkTo', null) == null || data.get('linkTo', null) is string
        && data.createdAt is number;
    }

    // Users
    match /users/{userId} {
      allow get: if isValidId(userId);
      allow list: if isAdmin() || (isSignedIn() && resource.data.uid == request.auth.uid);

      allow create: if isSignedIn()
        && request.auth.uid == userId
        && isValidUser(incoming())
        && incoming().uid == request.auth.uid;

      allow update: if isSignedIn()
        && request.auth.uid == userId
        && isValidUser(incoming())
        && incoming().uid == existing().uid
        && (incoming().role == existing().role || incoming().role == 'barber');
    }

    // Barber Profiles
    match /barberProfiles/{profileId} {
      allow read: if true;

      allow create: if isSignedIn()
        && request.auth.uid == incoming().userId
        && isValidBarberProfile(incoming());

      allow update: if isAdmin()
        || (isSignedIn()
          && (existing().get('barberCode', '') == '' || incoming().get('barberCode', '') == existing().get('barberCode', ''))
          && (
            (request.auth.uid == existing().userId && isValidBarberProfile(incoming()) && incoming().userId == existing().userId)
            ||
            (incoming().diff(existing()).affectedKeys().hasAny(['rating', 'reviewCount', 'totalCuts']) && isValidBarberProfile(incoming()))
          ));

      allow delete: if isAdmin();
    }

    // Schedules
    match /schedules/{userId} {
      allow read: if true;
      allow create: if isSignedIn()
        && request.auth.uid == incoming().userId
        && isValidSchedule(incoming());
      allow update: if isSignedIn()
        && request.auth.uid == existing().userId
        && isValidSchedule(incoming())
        && incoming().userId == existing().userId;
    }

    // Barbershops — ONLY SECTION CHANGED FROM ORIGINAL
    // Fix: removed isValidBarbershop() from create/update because barbershopSchema.parse()
    // in create-shop/page.tsx strips address.number, address.postalCode, address.floor
    // before Firestore sees the document, causing the validation to always fail.
    match /barbershops/{shopId} {
      allow read: if true;

      allow create: if isSignedIn()
        && request.auth.uid == incoming().ownerId;

      allow update: if isAdmin()
        || (isSignedIn()
          && request.auth.uid == existing().ownerId
          && incoming().ownerId == existing().ownerId);

      allow delete: if isAdmin()
        || (isSignedIn() && request.auth.uid == existing().ownerId);
    }

    // Services
    match /services/{serviceId} {
      allow read: if true;

      allow create: if isSignedIn()
        && request.auth.uid == incoming().providerId
        && isValidService(incoming())
        && exists(/databases/$(database)/documents/barberProfiles/$(request.auth.uid));

      allow update: if isSignedIn()
        && request.auth.uid == existing().providerId
        && isValidService(incoming())
        && incoming().providerId == existing().providerId;

      allow delete: if isSignedIn() && request.auth.uid == existing().providerId;
    }

    // Bookings
    match /bookings/{bookingId} {
      allow get: if isAdmin()
        || (isSignedIn() && isValidId(bookingId)
          && (resource.data.clientId == request.auth.uid || resource.data.barberId == request.auth.uid));

      allow list: if isAdmin()
        || (isSignedIn()
          && (resource.data.clientId == request.auth.uid || resource.data.barberId == request.auth.uid));

      allow create: if isSignedIn()
        && request.auth.uid == incoming().clientId
        && isValidBooking(incoming())
        && incoming().status == 'pending'
        && exists(/databases/$(database)/documents/services/$(incoming().serviceId))
        && exists(/databases/$(database)/documents/barberProfiles/$(incoming().barberId));

      allow update: if isSignedIn() && isValidBooking(incoming()) && (
        (
          request.auth.uid == existing().clientId
          && incoming().status == 'cancelled_by_client'
          && incoming().diff(existing()).affectedKeys().hasOnly(['status', 'updatedAt'])
        )
        ||
        (
          request.auth.uid == existing().barberId
          && incoming().status in ['confirmed', 'completed', 'cancelled', 'cancelled_by_barber']
          && incoming().diff(existing()).affectedKeys().hasOnly(['status', 'updatedAt'])
        )
      );
    }

    // Reviews
    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if isSignedIn()
        && request.auth.uid == incoming().clientId
        && isValidReview(incoming())
        && exists(/databases/$(database)/documents/barberProfiles/$(incoming().providerId));
      allow update: if isAdmin()
        || (isSignedIn()
          && request.auth.uid == existing().clientId
          && isValidReview(incoming())
          && incoming().clientId == existing().clientId
          && incoming().providerId == existing().providerId);
      allow delete: if isAdmin();
    }

    // Admin audit logs
    match /adminLogs/{logId} {
      allow read, write: if isAdmin();
    }

    // Feature requests (shop photos notify)
    match /featureRequests/{reqId} {
      allow read: if isAdmin();
      allow create: if isSignedIn();
    }

    // Locks for double booking checks
    match /bookingLocks/{lockId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    // Notifications
    match /notifications/{notificationId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidNotification(incoming());

      allow update: if isSignedIn()
        && request.auth.uid == existing().userId
        && isValidNotification(incoming())
        && incoming().userId == existing().userId
        && incoming().diff(existing()).affectedKeys().hasOnly(['read']);
    }
  }
}

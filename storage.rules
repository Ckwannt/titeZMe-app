rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /profile-photos/{uid}/{file} {
      allow read: if true;
      allow write: if request.auth != null 
        && request.auth.uid == uid
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }
    match /shop-profile/{uid}/{file} {
      allow read: if true;
      allow write: if request.auth != null
        && request.auth.uid == uid
        && file.matches('cover\\.jpg|logo\\.jpg')
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
      allow delete: if request.auth != null
        && request.auth.uid == uid;
    }
    match /portfolios/{uid}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null
        && request.auth.uid == uid
        && request.resource.size < 10 * 1024 * 1024
        && (request.resource.contentType.matches('image/.*')
            || request.resource.contentType.matches('video/.*'));
    }
    match /challenge-submissions/{uid}/{type}/{file} {
      allow read: if true;

      allow write: if request.auth != null
        && request.auth.uid == uid
        && (type == 'photos' || type == 'video')
        && (
          (type == 'photos'
            && request.resource.size < 1 * 1024 * 1024
            && request.resource.contentType.matches('image/.*'))
          ||
          (type == 'video'
            && request.resource.size < 10 * 1024 * 1024
            && request.resource.contentType.matches('video/.*'))
        );

      allow delete: if request.auth != null
        && request.auth.uid == uid;
    }
    match /challenge-reference-photos/{file} {
      allow read: if true;
      allow write, delete: if false;
    }
  }
}
